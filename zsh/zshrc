# Enable Powerlevel10k instant prompt. Must stay at the top.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ─── OS Detection ─────────────────────────────────────────────────────────────

is_macos() { [[ "$(uname -s)" == "Darwin" ]]; }
is_linux() { [[ "$(uname -s)" == "Linux" ]]; }

# ─── PATH ─────────────────────────────────────────────────────────────────────

export PATH="$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH"
export PATH="$HOME/.opencode/bin:$PATH"
export PATH="$PATH:$GOPATH/bin"
export PATH="$PATH:$HOME/.modular/bin"
export PATH="$PATH:$HOME/src/mx"
export PATH="$HOME/.pixi/bin:$PATH"

if is_macos; then
  export PATH="/opt/homebrew/bin:/opt/:$PATH"
  export HOMEBREW_NO_AUTO_UPDATE=1
fi

# Ghostty sets TERM=xterm-ghostty which isn't in Ubuntu's terminfo database.
# Force xterm-256color on Linux so keys (backspace, tab) work correctly.
if is_linux; then
  export TERM=xterm-256color
fi

# ─── Oh-My-Zsh ────────────────────────────────────────────────────────────────

export ZSH=~/.oh-my-zsh
ZSH_THEME="powerlevel10k/powerlevel10k"
DISABLE_UNTRACKED_FILES_DIRTY="true"

source $ZSH/oh-my-zsh.sh

# ─── Vi mode (must be after oh-my-zsh, which resets keybindings) ──────────────

bindkey -v

bindkey '^r' history-incremental-search-backward

# ─── Editor ───────────────────────────────────────────────────────────────────

export EDITOR=nvim

# ─── History ──────────────────────────────────────────────────────────────────

HISTFILE=~/.zsh_history
HISTSIZE=99999999999
SAVEHIST=$HISTSIZE
setopt hist_ignore_all_dups
setopt INC_APPEND_HISTORY
setopt HIST_SAVE_NO_DUPS
setopt HIST_REDUCE_BLANKS
setopt SHARE_HISTORY

# ─── Keybindings ──────────────────────────────────────────────────────────────

setopt auto_cd

export KEYTIMEOUT=1

# ─── Completions ──────────────────────────────────────────────────────────────

autoload bashcompinit && bashcompinit
autoload -Uz compinit && compinit

# ─── fzf ──────────────────────────────────────────────────────────────────────

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# ─── Pixi ─────────────────────────────────────────────────────────────────────

if command -v pixi &>/dev/null; then
  eval "$(pixi completion --shell zsh)"
fi

# ─── Conda / Git helpers ──────────────────────────────────────────────────────

function git_conda_activate() {
  # Activate a conda/pixi env matching the name of the current git repo
  local git_repo
  git_repo=$(git rev-parse --show-toplevel 2>/dev/null)
  if [[ -n "$git_repo" ]]; then
    local env_name
    env_name=$(basename "$git_repo" | sed 's/[^[:alnum:]]/_/g')
    conda activate "$env_name" 2>/dev/null || echo "No conda environment found for $env_name"
  else
    echo "Not a git repository"
  fi
}

function git_conda_create() {
  # Create a conda env matching the name of the current git repo
  local git_repo
  git_repo=$(git rev-parse --show-toplevel 2>/dev/null)
  if [[ -n "$git_repo" ]]; then
    local env_name
    env_name=$(basename "$git_repo" | sed 's/[^[:alnum:]]/_/g')
    conda create -n "$env_name" python="${1:-3.11}" && conda activate "$env_name"
  else
    echo "Not a git repository"
  fi
}

# ─── Docker helpers ───────────────────────────────────────────────────────────

function dkrRun() {
  docker run -it --rm --entrypoint "$1" "$2"
}

# Run a container with all GPUs exposed
function dkrGpu() {
  docker run -it --rm --gpus all "$@"
}

# Get container ID interactively (fzf) or by name
function did() {
  if [[ $# -eq 0 ]]; then
    docker ps | fzf -m | cut -d' ' -f1
  else
    docker ps -q --filter "name=$*"
  fi
}

# ─── Utility functions ────────────────────────────────────────────────────────

function diff_strs() {
  diff <(echo "$1") <(echo "$2")
}

function mysplit() {
  python3 -c "import sys; parts=sys.stdin.read().split('$1'); print('\n'.join(str(p) for p in parts))"
}

# ─── Quick queries -o opencode, -c claude ─────────────────────────────────────

qq() {
  local harness="opencode"

  while [[ $# -gt 0 ]]; do
    case $1 in
      -o|--opencode)
        harness="opencode"
        shift
        ;;
      -c|--claude)
        harness="claude"
        shift
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ $# -eq 0 ]]; then
    echo "Usage: qq [-o|-c] <your question>"
    echo "  -o, --opencode  use local Qwen3.5 (default)"
    echo "  -c, --claude    use Claude Haiku"
    return 1
  fi

  case $harness in
    opencode)
      OPENCODE_DISABLE_DEFAULT_PLUGINS=1 \
      OPENCODE_DISABLE_FILEWATCHER=1 \
      OPENCODE_DISABLE_AUTOCOMPACT=1 \
      OPENCODE_EXPERIMENTAL_OUTPUT_TOKEN_MAX=500 \
      opencode run --pure --log-level ERROR -m local/qwen35-int4 "$@"
      ;;
    claude)
      echo 'not implemented yet'
      ;;
  esac
}

# ─── Aliases ──────────────────────────────────────────────────────────────────

alias fbn="find . -name"
alias gw="./gradlew"
alias c=cd
alias g=git
alias kct=kubectl

if is_linux; then
  alias top=btop
  alias gpu='watch -n1 nvidia-smi'
fi

if is_macos; then
  alias ownusr="sudo chown -R \`whoami\` /usr/local/bin && sudo chown -R \`whoami\` /usr/local/lib"

  function fn_emacs() {
    emacsclient "$1" --alternate-editor /Applications/Emacs.app/Contents/MacOS/Emacs 2>/dev/null &
  }
  alias memacs="fn_emacs"
  alias em="fn_emacs"
fi

# ─── Platform-specific integrations ──────────────────────────────────────────

if is_macos; then
  # iTerm2 shell integration
  test -e "${HOME}/.iterm2_shell_integration.zsh" \
    && source "${HOME}/.iterm2_shell_integration.zsh"

  # SDKMAN
  export SDKMAN_DIR="$HOME/.sdkman"
  [[ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]] \
    && source "$HOME/.sdkman/bin/sdkman-init.sh"
fi

# ─── Private / local overrides ────────────────────────────────────────────────

[[ -f ~/.private.zshrc ]] && source ~/.private.zshrc

# ─── Prompt ───────────────────────────────────────────────────────────────────

[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh


